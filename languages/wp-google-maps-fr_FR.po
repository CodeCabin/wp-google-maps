#: wp-google-maps/html/settings-page.html.php:170
msgid "<strong>Default</strong> - The default front end."
msgstr "<strong>Par défaut</strong> : le frontal par défaut."

#: wp-google-maps/html/atlas-major/settings-page.html.php:395
#: wp-google-maps/html/atlas-novus/settings-page.html.php:395
#: wp-google-maps/html/settings-page.html.php:180
msgid "<strong>Modern</strong> - Puts components inside the map, with pull-out panels."
msgstr "<strong>Moderne</strong> : place les composants à l'intérieur de la carte, avec des panneaux coulissants."

#: wp-google-maps/html/atlas-major/settings-page.html.php:405
#: wp-google-maps/html/atlas-novus/settings-page.html.php:405
#: wp-google-maps/html/settings-page.html.php:190
msgid "<strong>Legacy</strong> - This setting is the same as Default, but provides options to change individual components to the modern style."
msgstr "<strong>Héritage</strong> : ce paramètre est identique à celui par défaut, mais fournit des options permettant de modifier les composants individuels vers le style moderne."

#: wp-google-maps/html/atlas-major/settings-page.html.php:415
#: wp-google-maps/html/atlas-novus/settings-page.html.php:415
#: wp-google-maps/html/settings-page.html.php:200
msgid "<strong>Compact</strong> - Puts all components and their labels inline."
msgstr "<strong>Compact</strong> : place tous les composants et leurs étiquettes en ligne."

#: wp-google-maps/html/atlas-major/settings-page.html.php:425
#: wp-google-maps/html/atlas-novus/settings-page.html.php:425
#: wp-google-maps/html/settings-page.html.php:210
msgid "<strong>Minimal</strong> - The same as Compact, but with icons instead of text labels."
msgstr "<strong>Minimal</strong> : identique à Compact, mais avec des icônes au lieu d'étiquettes de texte."

#: wp-google-maps/html/atlas-major/settings-page.html.php:435
#: wp-google-maps/html/atlas-novus/settings-page.html.php:435
#: wp-google-maps/html/settings-page.html.php:220
msgid "<strong>Bare Bones</strong> - Applies no styling to the components at all. This is recommended for designers and developers who want to style the components from scratch."
msgstr "<strong>Bare Bones</strong> : n'applique aucun style aux composants. Ceci est recommandé aux concepteurs et aux développeurs qui souhaitent styliser les composants à partir de zéro."

