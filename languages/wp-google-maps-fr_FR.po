msgstr "Exemples de paramètres d'étape :"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:76
#: wp-google-maps-gold/html/marker-rating-settings.html.php:93
#: wp-google-maps-pro/html/marker-rating-settings.html.php:89
msgid "0.01 :- Allow decimal / floating point ratings"
msgstr "0.01 : - Autoriser les évaluations décimales / à virgule flottante"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:77
#: wp-google-maps-gold/html/marker-rating-settings.html.php:98
#: wp-google-maps-pro/html/marker-rating-settings.html.php:94
msgid "1 :- Whole number ratings only"
msgstr "1 : Notes en nombre entier uniquement"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:78
#: wp-google-maps-gold/html/marker-rating-settings.html.php:103
#: wp-google-maps-pro/html/marker-rating-settings.html.php:99
msgid "5 :- Round to nearest five (eg for percentage ratings)"
msgstr "5 : - Arrondir au cinq le plus proche (par exemple pour les notes en pourcentage)"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:87
#: wp-google-maps-gold/html/marker-rating-settings.html.php:115
#: wp-google-maps-pro/html/marker-rating-settings.html.php:110
msgid "Widget Style"
msgstr "Style des widgets"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:110
#: wp-google-maps-gold/html/marker-rating-settings.html.php:137
msgid "Bar rating gradient colours:"
msgstr "Couleurs du dégradé de notation des barres :"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:117
#: wp-google-maps-gold/html/marker-rating-settings.html.php:145
msgid "Start -"
msgstr "Commencer -"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:121
#: wp-google-maps-gold/html/marker-rating-settings.html.php:151
msgid "End -"
msgstr "Fin -"

