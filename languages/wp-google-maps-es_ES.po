msgstr "Estilo de widget"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:110
#: wp-google-maps-gold/html/marker-rating-settings.html.php:137
msgid "Bar rating gradient colours:"
msgstr "Colores de degradado de la barra de calificación:"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:117
#: wp-google-maps-gold/html/marker-rating-settings.html.php:145
msgid "Start -"
msgstr "Inicio -"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:121
#: wp-google-maps-gold/html/marker-rating-settings.html.php:151
msgid "End -"
msgstr "Fin -"

