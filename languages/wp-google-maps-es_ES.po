msgid "Marker Ratings"
msgstr "Calificaciones de marcador"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:10
#: wp-google-maps-gold/html/marker-rating-settings.html.php:12
#: wp-google-maps-pro/html/marker-rating-settings.html.php:12
msgid "Minimum Rating"
msgstr "Calificación mínima"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:19
#: wp-google-maps-gold/html/marker-rating-settings.html.php:21
#: wp-google-maps-pro/html/marker-rating-settings.html.php:21
msgid "Maximum Rating"
msgstr "Calificación máxima"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:30
msgid "Please note that changing these settings will not scale ratings which have already been recorded."
msgstr "Tenga en cuenta que cambiar esta configuración no escalará las calificaciones que ya se hayan registrado."

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:32
msgid "We recommend that you do not modify the maximum and minimum settings after you begin accepting ratings."
msgstr "Le recomendamos que no modifique la configuración máxima y mínima después de comenzar a aceptar calificaciones."

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:42
#: wp-google-maps-gold/html/marker-rating-settings.html.php:41
#: wp-google-maps-pro/html/marker-rating-settings.html.php:41
