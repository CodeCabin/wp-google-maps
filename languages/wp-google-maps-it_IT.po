msgstr "Zoom massimo"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:30
msgid "Please note that changing these settings will not scale ratings which have already been recorded."
msgstr "Nota: modificare queste impostazioni non scala le valutazioni già registrate."

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:32
msgid "We recommend that you do not modify the maximum and minimum settings after you begin accepting ratings."
msgstr "Ti raccomandiamo di non modificare le impostazioni massimo/minimo dopo aver iniziato ad accettare valutazioni."

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:42
#: wp-google-maps-gold/html/marker-rating-settings.html.php:41
#: wp-google-maps-pro/html/marker-rating-settings.html.php:41
msgid "Example range settings:"
msgstr "Esempio di impostazioni dell'intervallo:"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:44
#: wp-google-maps-gold/html/marker-rating-settings.html.php:46
#: wp-google-maps-pro/html/marker-rating-settings.html.php:46
msgid "1 - 5 :- Traditional One to Five Stars"
msgstr "1 - 5 :- Tradizionale da una a cinque stelle"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:45
#: wp-google-maps-gold/html/marker-rating-settings.html.php:51
#: wp-google-maps-pro/html/marker-rating-settings.html.php:51
msgid "0 - 100 :- Percentage Rating"
msgstr "0 - 100 :- Valutazione in percentuale"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:46
#: wp-google-maps-gold/html/marker-rating-settings.html.php:56
#: wp-google-maps-pro/html/marker-rating-settings.html.php:56
msgid "0 - 1 :- Like / Dislike, or Upvote / Downvote"
msgstr "0 - 1 :- Like / Dislike o Upvote / Downvote"

#: wp-google-maps-gold/html/atlas-novus/marker-rating-settings.html.php:54
#: wp-google-maps-gold/html/marker-rating-settings.html.php:71
#: wp-google-maps-pro/html/marker-rating-settings.html.php:68
